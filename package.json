{
  "name": "MidNightCreation",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "turbo": "^2.10.4",
    "typescript": "5.9.2",
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.1.33"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/node": "^26.1.1",
    "i": "^0.3.7",
    "npm": "^11.18.0",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "prisma",
    "@prisma/client",
    "@prisma/engines"
  ],
  "module": "index.ts",
  "type": "module"
}
