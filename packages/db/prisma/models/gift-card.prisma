model GiftCard {
    id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    code         String               @unique
    initialValue Decimal              @map("initial_value") @db.Decimal(10, 2)
    balance      Decimal              @db.Decimal(10, 2)
    isActive     Boolean              @default(true) @map("is_active")
    expiresAt    DateTime?            @map("expires_at") @db.Timestamptz
    createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
    updatedAt    DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
    redemptions  GiftCardRedemption[]

    @@map("gift_cards")
}

model GiftCardRedemption {
    id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    giftCardId String   @map("gift_card_id") @db.Uuid
    orderId    String   @map("order_id") @db.Uuid
    amount     Decimal  @db.Decimal(10, 2)
    redeemedAt DateTime @default(now()) @map("redeemed_at") @db.Timestamptz

    giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
    order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@map("gift_card_redemptions")
}
