model ProductVariant {
    id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    productId    String   @map("product_id") @db.Uuid
    sku          String   @unique
    price        Decimal  @db.Decimal(10, 2)
    compareAt    Decimal? @map("compare_at") @db.Decimal(10, 2)
    weightOz     Decimal? @map("weight_oz") @db.Decimal(8, 2)
    inventoryQty Int      @default(0) @map("inventory_qty")
    optionValues Json     @default("{}") @map("option_values")
    imageUrl     String?  @map("image_url")
    isActive     Boolean  @default(true) @map("is_active")
    createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

    product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    cartItems  CartItem[]
    orderItems OrderItem[]

    @@map("product_variants")
}

model ProductImage {
    id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    productId String  @map("product_id") @db.Uuid
    url       String
    altText   String? @map("alt_text")
    sortOrder Int     @default(0) @map("sort_order")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("product_images")
}

model PersonalizationField {
    id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    productId  String  @map("product_id") @db.Uuid
    label      String
    fieldType  String  @map("field_type")
    maxLength  Int?    @map("max_length")
    extraPrice Decimal @default(0) @map("extra_price") @db.Decimal(10, 2)
    isRequired Boolean @default(false) @map("is_required")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("personalization_fields")
}
