// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  organizer
  staff
  admin
}

enum PrintMethod {
  screen_print
  embroidery
  sublimation
  laser_engraving
  dtf
  vinyl
}

enum StoreType {
  fundraiser
  team
  school
  business
}

enum StoreStatus {
  pending
  live
  ended
  archived
}

enum OrderStatus {
  pending_payment
  paid
  in_production
  ready_for_pickup
  shipped
  delivered
  cancelled
  refunded
}

enum QuoteStatus {
  submitted
  ai_estimated
  quoted
  approved
  rejected
  converted
  expired
}

enum ProductionStatus {
  queued
  in_production
  ready
  shipped
}

