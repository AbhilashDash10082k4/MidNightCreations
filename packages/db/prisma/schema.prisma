model ProductVariant {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  sku          String   @unique
  price        Decimal  @db.Decimal(10, 2)
  compareAt    Decimal? @map("compare_at") @db.Decimal(10, 2)
  weightOz     Decimal? @map("weight_oz") @db.Decimal(8, 2)
  inventoryQty Int      @default(0) @map("inventory_qty")
  optionValues Json     @default("{}") @map("option_values")
  imageUrl     String?  @map("image_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model PersonalizationField {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  label      String
  fieldType  String  @map("field_type")
  maxLength  Int?    @map("max_length")
  extraPrice Decimal @default(0) @map("extra_price") @db.Decimal(10, 2)
  isRequired Boolean @default(false) @map("is_required")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("personalization_fields")
}

model Store {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String      @unique
  name             String
  type             StoreType
  status           StoreStatus @default(pending)
  ownerUserId      String      @map("owner_user_id") @db.Uuid
  accountManagerId String?     @map("account_manager_id") @db.Uuid
  commissionPct    Decimal     @default(10.00) @map("commission_pct") @db.Decimal(5, 2)
  goalAmount       Decimal?    @map("goal_amount") @db.Decimal(10, 2)
  theme            Json        @default("{}")
  startsAt         DateTime?   @map("starts_at") @db.Timestamptz
  endsAt           DateTime?   @map("ends_at") @db.Timestamptz
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz

  owner          User           @relation("StoreOwner", fields: [ownerUserId], references: [id])
  accountManager User?          @relation("StoreManager", fields: [accountManagerId], references: [id])
  members        StoreMember[]
  storeProducts  StoreProduct[]
  // marketingAssets StoreMarketingAsset[]
  payouts        StorePayout[]
  carts          Cart[]
  orders         Order[]
  discounts      Discount[]

  @@map("stores")
}

model StoreMember {
  storeId String @map("store_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid
  role    String @default("organizer")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storeId, userId])
  @@map("store_members")
}

model StoreProduct {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId       String   @map("store_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  overridePrice Decimal? @map("override_price") @db.Decimal(10, 2)
  isExclusive   Boolean  @default(false) @map("is_exclusive")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("store_products")
}

