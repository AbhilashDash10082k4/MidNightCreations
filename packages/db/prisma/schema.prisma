model OrderStatusHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  note      String?
  changedBy String?     @map("changed_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [changedBy], references: [id])

  @@map("order_status_history")
}

model Payment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  provider    String   @default("stripe")
  providerRef String   @map("provider_ref")
  amount      Decimal  @db.Decimal(12, 2)
  status      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Shipment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  carrier     String?
  trackingNo  String?   @map("tracking_no")
  labelUrl    String?   @map("label_url")
  shippedAt   DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

model Discount {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String    @unique
  type      String
  value     Decimal   @db.Decimal(10, 2)
  storeId   String?   @map("store_id") @db.Uuid
  startsAt  DateTime? @map("starts_at") @db.Timestamptz
  endsAt    DateTime? @map("ends_at") @db.Timestamptz
  maxUses   Int?      @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  isActive  Boolean   @default(true) @map("is_active")

  store Store? @relation(fields: [storeId], references: [id])

  @@map("discounts")
}

model QuoteRequest {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String?      @map("user_id") @db.Uuid
  contactName         String       @map("contact_name")
  contactEmail        String       @map("contact_email")
  contactPhone        String?      @map("contact_phone")
  organization        String?
  decorationMethod    PrintMethod? @map("decoration_method")
  garmentType         String?      @map("garment_type")
  quantity            Int?
  neededBy            DateTime?    @map("needed_by") @db.Date
  notes               String?
  aiExtracted         Json?        @map("ai_extracted")
  aiPriceEstimateLow  Decimal?     @map("ai_price_estimate_low") @db.Decimal(10, 2)
  aiPriceEstimateHigh Decimal?     @map("ai_price_estimate_high") @db.Decimal(10, 2)
  status              QuoteStatus  @default(submitted)
  assignedStaffId     String?      @map("assigned_staff_id") @db.Uuid
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user          User?             @relation("QuoteUser", fields: [userId], references: [id])
  assignedStaff User?             @relation("QuoteAssignee", fields: [assignedStaffId], references: [id])
  attachments   QuoteAttachment[]
  lineItems     QuoteLineItem[]
  messages      QuoteMessage[]

  @@map("quote_requests")
}

model QuoteAttachment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId      String   @map("quote_id") @db.Uuid
  fileUrl      String   @map("file_url")
  fileName     String?  @map("file_name")
  scannedClean Boolean? @default(false) @map("scanned_clean")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  quote QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_attachments")
}

model QuoteLineItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId     String  @map("quote_id") @db.Uuid
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)

  quote QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_line_items")
}

model QuoteMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId   String   @map("quote_id") @db.Uuid
  senderId  String?  @map("sender_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  quote  QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sender User?        @relation(fields: [senderId], references: [id])

  @@map("quote_messages")
}

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  rating      Int
  title       String?
  body        String?
  aiSummary   String?  @map("ai_summary")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  wishlistId String @map("wishlist_id") @db.Uuid
  productId  String @map("product_id") @db.Uuid

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([wishlistId, productId])
  @@map("wishlist_items")
}

model CmsPage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  title       String
  blocks      Json     @default("[]")
  isPublished Boolean  @default(true) @map("is_published")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("cms_pages")
}

model EmailSubscriber {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  source       String?
  subscribedAt DateTime @default(now()) @map("subscribed_at") @db.Timestamptz

  @@map("email_subscribers")
}

