// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  organizer
  staff
  admin
}

enum PrintMethod {
  screen_print
  embroidery
  sublimation
  laser_engraving
  dtf
  vinyl
}

enum StoreType {
  fundraiser
  team
  school
  business
}

enum StoreStatus {
  pending
  live
  ended
  archived
}

enum OrderStatus {
  pending_payment
  paid
  in_production
  ready_for_pickup
  shipped
  delivered
  cancelled
  refunded
}

enum QuoteStatus {
  submitted
  ai_estimated
  quoted
  approved
  rejected
  converted
  expired
}

enum ProductionStatus {
  queued
  in_production
  ready
  shipped
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  phone           String?
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  role            UserRole  @default(customer)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  avatarUrl       String?   @map("avatar_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  oauthAccounts    OauthAccount[]
  addresses        Address[]
  storesOwned      Store[]              @relation("StoreOwner")
  storesManaged    Store[]              @relation("StoreManager")
  storeMemberships StoreMember[]
  carts            Cart[]
  orders           Order[]
  quoteRequests    QuoteRequest[]       @relation("QuoteUser")
  quotesAssigned   QuoteRequest[]       @relation("QuoteAssignee")
  quoteMessages    QuoteMessage[]
  reviews          Review[]
  wishlists        Wishlist[]
  userEvents       UserEvent[]
  // chatConversations ChatConversation[]
  productionJobs   ProductionJob[]
  statusChanges    OrderStatusHistory[]

  @@map("users")
}

model OauthAccount {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  provider    String
  providerUid String   @map("provider_uid")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("oauth_accounts")
}

model Address {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  label      String?
  fullName   String   @map("full_name")
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String   @map("postal_code")
  country    String   @default("US")
  phone      String?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@map("addresses")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  parent   Category?         @relation("SubCategories", fields: [parentId], references: [id])
  children Category[]        @relation("SubCategories")
  products ProductCategory[]

  @@map("categories")
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String   @unique
  name           String
  description    String?
  basePrice      Decimal  @map("base_price") @db.Decimal(10, 2)
  currency       String   @default("USD")
  status         String   @default("active")
  isCustomizable Boolean  @default(false) @map("is_customizable")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  categories       ProductCategory[]
  printMethods     ProductPrintMethod[]
  variants         ProductVariant[]
  images           ProductImage[]
  personalizations PersonalizationField[]
  storeProducts    StoreProduct[]
  reviews          Review[]
  wishlists        WishlistItem[]
  userEvents       UserEvent[]
  // embedding        ProductEmbedding?

  @@map("products")
}

model ProductCategory {
  productId  String @map("product_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductPrintMethod {
  productId   String      @map("product_id") @db.Uuid
  printMethod PrintMethod @map("print_method")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, printMethod])
  @@map("product_print_methods")
}

